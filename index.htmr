<!DOCTYPE html>
<html lang="ko">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0, maximum-scale=1.0, user-scalable=no">
    <title>네온 던전 크롤러 JRPG</title>
    <!-- Tailwind CSS 로드 -->
    <script src="https://cdn.tailwindcss.com"></script>
    <style>
        @import url('https://fonts.googleapis.com/css2?family=Cinzel:wght@700;900&family=Orbitron:wght@400;700;900&display=swap');
        
        .font-fantasy {
            font-family: 'Cinzel', serif;
        }
        .font-neon {
            font-family: 'Orbitron', sans-serif;
        }
        body {
            touch-action: none; /* 모바일 밀림 및 줌 방지 */
            background-color: #020617;
        }
        
        /* 스크롤바 디자인 */
        #combat-log::-webkit-scrollbar { width: 4px; }
        #combat-log::-webkit-scrollbar-track { background: rgba(15, 23, 42, 0.6); }
        #combat-log::-webkit-scrollbar-thumb { background: #334155; border-radius: 2px; }
        
        /* 글로우 효과 */
        .glow-blue { text-shadow: 0 0 6px #3b82f6, 0 0 15px #1d4ed8; }
        .glow-red { text-shadow: 0 0 6px #ef4444, 0 0 15px #991b1b; }
        .glow-gold { text-shadow: 0 0 6px #f59e0b, 0 0 15px #b45309; }
    </style>
</head>
<body class="text-slate-100 flex items-center justify-center min-h-screen p-2 overflow-hidden select-none">

    <!-- 메인 프레임워크 컨테이너 -->
    <div class="relative w-full max-w-lg aspect-[9/16] bg-slate-950 rounded-3xl overflow-hidden border-2 border-slate-800 shadow-[0_0_35px_rgba(59,130,246,0.15)] flex flex-col">
        
        <div class="bg-slate-900/90 border-b border-slate-800 p-3 flex justify-between items-center z-10 font-neon">
            <div>
                <p class="text-[9px] text-sky-400 font-bold uppercase tracking-wider">HERO STATUS</p>
                <p id="hud-level-text" class="text-sm font-black text-white glow-blue">LV.1 WARRIOR</p>
            </div>
            <div class="text-center">
                <p class="text-[9px] text-emerald-400 font-bold uppercase tracking-wider">DUNGEON FLOOR</p>
                <p id="hud-floor-text" class="text-sm font-black text-emerald-400">B1 DEPTHS</p>
            </div>
            <div class="text-right">
                <p class="text-[9px] text-amber-500 font-bold uppercase tracking-wider">GOLD COINS</p>
                <p id="hud-gold-text" class="text-sm font-black text-yellow-400 glow-gold">🪙 30 G</p>
            </div>
        </div>

        <div class="bg-slate-900/60 p-2.5 border-b border-slate-800 flex flex-col gap-1.5 z-10 font-neon text-[10px]">
            <div class="flex items-center justify-between">
                <span class="text-red-400 font-bold">❤️ HEALTH (HP)</span>
                <span id="hud-hp-val" class="font-bold text-red-200">35 / 35</span>
            </div>
            <div class="w-full bg-slate-950 h-2 rounded-full overflow-hidden border border-red-500/10">
                <div id="hud-hp-bar" class="h-full bg-gradient-to-r from-red-600 to-rose-400 transition-all duration-200" style="width: 100%"></div>
            </div>

            <div class="flex items-center justify-between">
                <span class="text-sky-400 font-bold">✨ PROGRESS (EXP)</span>
                <span id="hud-exp-val" class="font-bold text-sky-200">0 / 15</span>
            </div>
            <div class="w-full bg-slate-950 h-1.5 rounded-full overflow-hidden border border-sky-500/10">
                <div id="hud-exp-bar" class="h-full bg-gradient-to-r from-sky-500 to-indigo-500 transition-all duration-200" style="width: 0%"></div>
            </div>
        </div>

        <div class="relative flex-1 bg-slate-950 w-full overflow-hidden flex items-center justify-center">
            <canvas id="dungeonCanvas" class="w-full max-w-full block"></canvas>
            
            <!-- 포탈 열림 알림 오버레이 배너 -->
            <div id="portal-banner" class="absolute inset-x-0 top-1/4 text-center pointer-events-none hidden transition-all duration-300">
                <h1 class="text-2xl font-black text-emerald-400 font-fantasy tracking-wider animate-pulse glow-blue">🚪 PORTAL IS OPEN!</h1>
                <p class="text-[10px] text-emerald-300 uppercase font-neon">Defeated all monsters. Find the Portal!</p>
            </div>
        </div>

        <div class="bg-slate-900 border-t border-slate-800 p-3 flex flex-col gap-3 relative z-10">
            
            <!-- 실시간 배틀 텍스트 로그 영역 -->
            <div id="combat-log" class="h-16 bg-slate-950/80 rounded-xl p-2.5 overflow-y-auto font-mono text-[11px] text-slate-400 border border-slate-800/40 space-y-1">
                <div class="text-sky-400 font-bold">🛡️ 던전에 도달했습니다. 몬스터를 물리치고 보물을 모으세요!</div>
            </div>

            <!-- 하단 격자 레이아웃 (D-pad & 포션 퀵액션) -->
            <div class="grid grid-cols-12 gap-3 items-center">
                
                <!-- 퀵 치료 물약 -->
                <button id="btn-potion" class="col-span-4 py-3 bg-gradient-to-b from-slate-850 to-slate-900 hover:from-slate-800 hover:to-slate-850 border border-slate-700 rounded-2xl flex flex-col items-center justify-center shadow-lg transition-transform active:scale-95">
                    <span class="text-xl">🧪</span>
                    <span class="text-[10px] font-bold mt-1 text-slate-200 font-neon">POTION (<span id="potion-qty-badge">1</span>)</span>
                    <span class="text-[8px] text-emerald-400 font-bold mt-0.5">Heal +20 HP</span>
                </button>

                <!-- 십자 가상 조이패드 (D-Pad) -->
                <div class="col-span-8 flex justify-center items-center">
                    <div class="grid grid-cols-3 gap-1 w-28 h-28 relative">
                        <div></div>
                        <button id="btn-up" class="py-2.5 bg-slate-800 hover:bg-slate-700 border border-slate-700 rounded-xl flex items-center justify-center text-white font-bold active:scale-90 transition-transform">🔺</button>
                        <div></div>
                        <button id="btn-left" class="py-2.5 bg-slate-800 hover:bg-slate-700 border border-slate-700 rounded-xl flex items-center justify-center text-white font-bold active:scale-90 transition-transform">◀️</button>
                        <div class="flex items-center justify-center text-xs text-slate-600 font-black font-neon">MOVE</div>
                        <button id="btn-right" class="py-2.5 bg-slate-800 hover:bg-slate-700 border border-slate-700 rounded-xl flex items-center justify-center text-white font-bold active:scale-90 transition-transform">▶️</button>
                        <div></div>
                        <button id="btn-down" class="py-2.5 bg-slate-800 hover:bg-slate-700 border border-slate-700 rounded-xl flex items-center justify-center text-white font-bold active:scale-90 transition-transform">🔻</button>
                        <div></div>
                    </div>
                </div>

            </div>
        </div>

        <div id="start-screen" class="absolute inset-0 bg-slate-950/95 flex flex-col items-center justify-center p-6 z-20 transition-all duration-300">
            <div class="text-7xl mb-4 animate-bounce">🏰</div>
            <h1 class="text-3xl font-black text-center text-sky-500 font-fantasy tracking-wider uppercase mb-1 glow-blue">NEON CRAWLER</h1>
            <p class="text-xs text-sky-500/70 font-neon uppercase tracking-widest mb-6">2D Visual Roguelike JRPG</p>
            <p class="text-xs text-slate-400 text-center max-w-xs mb-8 leading-relaxed">
                가상의 네온 타일 격자 던전에 입장하세요!<br>
                몬스터를 물리쳐 포탈 문을 열고 아래층으로 전진하세요. 맵 위의 상점(<strong class="text-amber-400">🏪</strong>)이나 상자(<strong class="text-yellow-300">🎁</strong>)와 접촉하면 힘을 기를 수 있습니다!
            </p>
            <button id="btn-start" class="px-8 py-4 bg-gradient-to-r from-sky-600 to-blue-600 hover:brightness-110 active:scale-95 transition-all text-white font-black tracking-wider rounded-2xl shadow-lg shadow-sky-950/50 border border-sky-400">
                🗡️ 던전으로 하강하기
            </button>
        </div>

        <div id="shop-screen" class="absolute inset-0 bg-slate-950/95 flex flex-col items-center justify-center p-6 z-20 hidden">
            <div class="text-5xl mb-2">🏪</div>
            <h2 class="text-2xl font-black text-amber-500 font-fantasy mb-1">DUNGEON SHOP</h2>
            <p class="text-[11px] text-slate-400 mb-6 font-neon">The wandering merchant is selling mystical items.</p>

            <div class="text-sm font-bold text-amber-400 mb-4 flex items-center gap-1 font-neon">
                🪙 MY GOLD: <span id="shop-gold-val" class="text-lg text-white font-black">30</span> G
            </div>

            <!-- 구매 장비 목록 -->
            <div class="w-full space-y-3 mb-6 max-w-xs font-neon">
                <!-- 무기 연마 -->
                <button id="shop-buy-atk" class="w-full flex justify-between items-center bg-slate-900 p-3 rounded-xl border border-slate-800 hover:border-red-500 transition-colors text-left active:scale-95">
                    <div>
                        <div class="font-bold text-xs text-red-400">⚔️ 루비 그레이트 소드</div>
                        <div class="text-[10px] text-slate-500">기본 공격력이 영구히 3만큼 상승합니다.</div>
                    </div>
                    <span id="shop-atk-cost" class="text-xs font-bold text-amber-400 bg-slate-950 px-2.5 py-1 rounded border border-slate-800">🪙 30G</span>
                </button>
                <!-- 갑옷 강화 -->
                <button id="shop-buy-def" class="w-full flex justify-between items-center bg-slate-900 p-3 rounded-xl border border-slate-800 hover:border-amber-500 transition-colors text-left active:scale-95">
                    <div>
                        <div class="font-bold text-xs text-amber-400">🛡️ 사자문장 판금 갑옷</div>
                        <div class="text-[10px] text-slate-500">받는 모든 물리 피해가 1씩 차단됩니다.</div>
                    </div>
                    <span id="shop-def-cost" class="text-xs font-bold text-amber-400 bg-slate-950 px-2.5 py-1 rounded border border-slate-800">🪙 40G</span>
                </button>
                <!-- 회복 물약 -->
                <button id="shop-buy-pot" class="w-full flex justify-between items-center bg-slate-900 p-3 rounded-xl border border-slate-800 hover:border-emerald-500 transition-colors text-left active:scale-95">
                    <div>
                        <div class="font-bold text-xs text-emerald-400">🧪 치유의 엘릭서</div>
                        <div class="text-[10px] text-slate-500">긴급상황 시 체력을 치유해 주는 포션 1개 소지.</div>
                    </div>
                    <span id="shop-pot-cost" class="text-xs font-bold text-amber-400 bg-slate-950 px-2.5 py-1 rounded border border-slate-800">🪙 15G</span>
                </button>
            </div>

            <button id="btn-shop-close" class="px-8 py-3 bg-slate-800 hover:bg-slate-700 active:scale-95 transition-all text-slate-100 font-bold text-xs rounded-xl shadow-lg border border-slate-700 font-neon">
                🔙 대화 종료 (다시 탐색하기)
            </button>
        </div>

        <div id="gameover-screen" class="absolute inset-0 bg-slate-950/95 flex flex-col items-center justify-center p-6 z-20 hidden">
            <div class="text-6xl mb-4 animate-bounce">💀</div>
            <h1 class="text-3xl font-black text-red-500 font-fantasy uppercase tracking-widest mb-1 glow-red">HERO DEFEATED</h1>
            <p class="text-xs text-slate-400 mb-6">You have succumbed to the darkness of the dungeon.</p>
            
            <div class="bg-slate-900 p-4 rounded-xl border border-slate-800 w-full max-w-xs text-sm mb-6 space-y-2 font-neon">
                <div class="flex justify-between"><span class="text-slate-500">최대 도달 깊이</span><span id="go-floor" class="text-emerald-400 font-bold">B1 DEPTHS</span></div>
                <div class="flex justify-between"><span class="text-slate-500">누적 처치수</span><span id="go-kills" class="text-red-400 font-bold">0 MONSTERS</span></div>
            </div>

            <button id="btn-retry" class="px-8 py-4 bg-gradient-to-r from-red-600 to-rose-600 hover:brightness-110 active:scale-95 transition-all text-white font-bold tracking-widest rounded-2xl shadow-lg border border-red-400 font-neon">
                🛡️ 다시 영혼을 충전하여 재도전
            </button>
        </div>

    </div>

    <script>
        (() => {
            // --- 브라우저 합성 사운드 효과 (Web Audio API) ---
            const audioCtx = new (window.AudioContext || window.webkitAudioContext)();
            
            function playSound(type) {
                if (audioCtx.state === 'suspended') {
                    audioCtx.resume();
                }
                const osc = audioCtx.createOscillator();
                const gain = audioCtx.createGain();
                osc.connect(gain);
                gain.connect(audioCtx.destination);

                if (type === 'move') {
                    // 미세한 부스럭 소리
                    osc.type = 'sine';
                    osc.frequency.setValueAtTime(150, audioCtx.currentTime);
                    osc.frequency.linearRampToValueAtTime(50, audioCtx.currentTime + 0.08);
                    gain.gain.setValueAtTime(0.04, audioCtx.currentTime);
                    gain.gain.linearRampToValueAtTime(0.001, audioCtx.currentTime + 0.08);
                    osc.start();
                    osc.stop(audioCtx.currentTime + 0.08);
                } else if (type === 'hit') {
                    // 둔탁하게 타격하는 무거운 소리
                    osc.type = 'triangle';
                    osc.frequency.setValueAtTime(160, audioCtx.currentTime);
                    osc.frequency.exponentialRampToValueAtTime(30, audioCtx.currentTime + 0.15);
                    gain.gain.setValueAtTime(0.2, audioCtx.currentTime);
                    gain.gain.linearRampToValueAtTime(0.001, audioCtx.currentTime + 0.15);
                    osc.start();
                    osc.stop(audioCtx.currentTime + 0.15);
                } else if (type === 'heal') {
                    // 신비한 업비트 음계
                    osc.type = 'sine';
                    osc.frequency.setValueAtTime(330, audioCtx.currentTime);
                    osc.frequency.exponentialRampToValueAtTime(660, audioCtx.currentTime + 0.25);
                    gain.gain.setValueAtTime(0.08, audioCtx.currentTime);
                    gain.gain.linearRampToValueAtTime(0.001, audioCtx.currentTime + 0.25);
                    osc.start();
                    osc.stop(audioCtx.currentTime + 0.25);
                } else if (type === 'coin') {
                    // 반짝이는 동전 아르페지오 소리
                    osc.type = 'sine';
                    osc.frequency.setValueAtTime(523.25, audioCtx.currentTime); // C5
                    osc.frequency.setValueAtTime(659.25, audioCtx.currentTime + 0.08); // E5
                    osc.frequency.setValueAtTime(783.99, audioCtx.currentTime + 0.16); // G5
                    gain.gain.setValueAtTime(0.06, audioCtx.currentTime);
                    gain.gain.linearRampToValueAtTime(0.001, audioCtx.currentTime + 0.3);
                    osc.start();
                    osc.stop(audioCtx.currentTime + 0.3);
                } else if (type === 'levelup') {
                    // 영광의 승리 하모닉스
                    osc.type = 'sine';
                    osc.frequency.setValueAtTime(440, audioCtx.currentTime);
                    osc.frequency.linearRampToValueAtTime(880, audioCtx.currentTime + 0.4);
                    gain.gain.setValueAtTime(0.12, audioCtx.currentTime);
                    gain.gain.linearRampToValueAtTime(0.001, audioCtx.currentTime + 0.45);
                    osc.start();
                    osc.stop(audioCtx.currentTime + 0.45);
                } else if (type === 'nextfloor') {
                    // 던전 더 아래로 울리는 잔향
                    osc.type = 'sawtooth';
                    osc.frequency.setValueAtTime(100, audioCtx.currentTime);
                    osc.frequency.linearRampToValueAtTime(40, audioCtx.currentTime + 0.5);
                    gain.gain.setValueAtTime(0.15, audioCtx.currentTime);
                    gain.gain.linearRampToValueAtTime(0.001, audioCtx.currentTime + 0.5);
                    osc.start();
                    osc.stop(audioCtx.currentTime + 0.5);
                }
            }

            // --- STREAMING_CHUNK: 게임 핵심 설정 및 자료구조 선언 ---
            const canvas = document.getElementById('dungeonCanvas');
            const ctx = canvas.getContext('2d');

            // 던전 격자 크기 지정 (9행 9열 배치)
            const GRID_ROWS = 9;
            const GRID_COLS = 9;
            let tileSize = 0;

            function scaleCanvas() {
                // 부모의 크기 안에서 반응형 격자 사이즈 자동 배분
                canvas.width = canvas.parentElement.clientWidth;
                canvas.height = canvas.width; // 1:1 정밀 격자 비율
                tileSize = canvas.width / GRID_COLS;
            }
            scaleCanvas();
            window.addEventListener('resize', scaleCanvas);

            // 용사 스태프 정보
            let hero = {
                x: 0,
                y: 0,
                level: 1,
                hp: 35,
                maxHp: 35,
                atk: 7,
                def: 0,
                exp: 0,
                maxExp: 15,
                gold: 30,
                potions: 1,
                kills: 0,
                floor: 1,
                upgrades: { atk: 0, def: 0, pot: 0 },
                upgradeCosts: { atk: 30, def: 40, pot: 15 }
            };

            // 월드 타일 유형 정의
            const TILE_FLOOR = 0;
            const TILE_WALL = 1;
            const TILE_PORTAL = 2;
            const TILE_SHOP = 3;
            const TILE_CHEST = 4;
            const TILE_MONSTER = 5;

            // 월드 맵 및 개체 테이블
            let mapGrid = [];
            let entities = []; // 몬스터, 상자 등 격자 위의 개체 배열
            let floatingTexts = []; // 타격 시 뿜어 나오는 플로팅 텍스트
            let isPortalOpen = false;

            // 몬스터 등급 정보 데이터 테이블
            const monsterTemplates = [
                { name: "초록 슬라임", emoji: "👾", baseHp: 12, baseAtk: 4, gold: 10, exp: 5 },
                { name: "들개 늑대", emoji: "🐺", baseHp: 18, baseAtk: 6, gold: 15, exp: 8 },
                { name: "광부 고블린", emoji: "👹", baseHp: 28, baseAtk: 10, gold: 20, exp: 12 },
                { name: "어둠의 외눈거인", emoji: "👁️", baseHp: 45, baseAtk: 15, gold: 30, exp: 20 },
                { name: "마그마 웜", emoji: "🐛", baseHp: 70, baseAtk: 22, gold: 50, exp: 35 }
            ];

            // --- STREAMING_CHUNK: 가상 로그 작성 관리기 ---
            function log(message, color = "text-slate-300") {
                const logPanel = document.getElementById('combat-log');
                const div = document.createElement('div');
                div.className = color;
                div.innerHTML = message;
                logPanel.appendChild(div);
                logPanel.scrollTop = logPanel.scrollHeight;
            }

            // HUD UI 동기화
            function updateHUD() {
                document.getElementById('hud-level-text').innerText = `LV.${hero.level} GLADIATOR`;
                document.getElementById('hud-floor-text').innerText = `B${hero.floor} DEPTHS`;
                document.getElementById('hud-gold-text').innerText = `🪙 ${hero.gold} G`;
                
                document.getElementById('hud-hp-val').innerText = `${hero.hp} / ${hero.maxHp}`;
                document.getElementById('hud-hp-bar').style.width = `${Math.max(0, (hero.hp / hero.maxHp) * 100)}%`;
                
                document.getElementById('hud-exp-val').innerText = `${hero.exp} / ${hero.maxExp}`;
                document.getElementById('hud-exp-bar').style.width = `${Math.min(100, (hero.exp / hero.maxExp) * 100)}%`;
                
                document.getElementById('potion-qty-badge').innerText = hero.potions;
            }

            // --- STREAMING_CHUNK: 맵 생성기 및 던전 오토 리셋 ---
            function generateDungeon() {
                mapGrid = [];
                entities = [];
                isPortalOpen = false;
                document.getElementById('portal-banner').classList.add('hidden');

                // 1. 빈 방 개설
                for (let r = 0; r < GRID_ROWS; r++) {
                    mapGrid[r] = [];
                    for (let c = 0; c < GRID_COLS; c++) {
                        // 가장자리는 강제로 벽 처리
                        if (r === 0 || r === GRID_ROWS - 1 || c === 0 || c === GRID_COLS - 1) {
                            mapGrid[r][c] = TILE_WALL;
                        } else {
                            mapGrid[r][c] = TILE_FLOOR;
                        }
                    }
                }

                // 2. 던전 내부 무작위 기둥 배치
                for (let i = 0; i < 6; i++) {
                    const r = Math.floor(1 + Math.random() * (GRID_ROWS - 2));
                    const c = Math.floor(1 + Math.random() * (GRID_COLS - 2));
                    // 시작 영역(1,1)은 기둥 배제
                    if (r === 1 && c === 1) continue;
                    mapGrid[r][c] = TILE_WALL;
                }

                // 3. 용사 배치 (항상 좌측 상단)
                hero.x = 1;
                hero.y = 1;

                // 4. 상점 배치
                spawnOnFreeTile(TILE_SHOP, "🏪");

                // 5. 보물상자 배치 (1~2개)
                const chestCount = 1 + Math.floor(Math.random() * 2);
                for (let i = 0; i < chestCount; i++) {
                    spawnOnFreeTile(TILE_CHEST, "🎁");
                }

                // 6. 다음 층 하강 포탈 생성 (비밀의 포탈)
                spawnOnFreeTile(TILE_PORTAL, "🚪");

                // 7. 몬스터 스폰 (3~4마리)
                const monsterCount = 3 + Math.floor(Math.random() * 2);
                for (let i = 0; i < monsterCount; i++) {
                    spawnMonster();
                }

                updateHUD();
                log(` B${hero.floor}층에 진입했습니다! 주변의 방을 정찰하세요.`, 'text-sky-300');
            }

            function spawnOnFreeTile(type, emoji) {
                while (true) {
                    const r = Math.floor(1 + Math.random() * (GRID_ROWS - 2));
                    const c = Math.floor(1 + Math.random() * (GRID_COLS - 2));
                    if (mapGrid[r][c] === TILE_FLOOR && !(r === 1 && c === 1) && !getEntityAt(c, r)) {
                        entities.push({
                            x: c,
                            y: r,
                            type: type,
                            emoji: emoji,
                            hp: 1,
                            maxHp: 1,
                            active: true
                        });
                        break;
                    }
                }
            }

            function spawnMonster() {
                // 플레이어 층 수준에 비례하여 높은 몬스터 배분
                const difficulty = Math.min(monsterTemplates.length - 1, Math.floor((hero.floor - 1) / 2));
                const randIndex = Math.floor(Math.random() * (difficulty + 1));
                const template = monsterTemplates[randIndex];

                while (true) {
                    const r = Math.floor(1 + Math.random() * (GRID_ROWS - 2));
                    const c = Math.floor(1 + Math.random() * (GRID_COLS - 2));
                    // 아군 근처 배제하여 급습 방지
                    if (mapGrid[r][c] === TILE_FLOOR && Math.hypot(c - hero.x, r - hero.y) > 2 && !getEntityAt(c, r)) {
                        
                        entities.push({
                            x: c,
                            y: r,
                            type: TILE_MONSTER,
                            emoji: template.emoji,
                            name: template.name,
                            hp: template.baseHp + (hero.floor - 1) * 6,
                            maxHp: template.baseHp + (hero.floor - 1) * 6,
                            atk: template.baseAtk + (hero.floor - 1) * 2,
                            gold: template.gold + (hero.floor - 1) * 3,
                            exp: template.exp + (hero.floor - 1) * 2,
                            active: true
                        });
                        break;
                    }
                }
            }

            function getEntityAt(x, y) {
                return entities.find(e => e.x === x && e.y === y && e.active);
            }

            // --- STREAMING_CHUNK: 플로팅 텍스트 생성 모듈 ---
            function createFloatingText(x, y, text, color = '#ffffff') {
                floatingTexts.push({
                    x: x * tileSize + tileSize / 2,
                    y: y * tileSize,
                    text: text,
                    color: color,
                    alpha: 1,
                    life: 45 // 프레임 라이프사이클
                });
            }

            // --- STREAMING_CHUNK: 그리드 맵 실시간 렌더링 엔진 ---
            function drawDungeon() {
                // 기저 다크 클리어
                ctx.fillStyle = '#020617';
                ctx.fillRect(0, 0, canvas.width, canvas.height);

                // 1. 타일층 백 그라운드
                for (let r = 0; r < GRID_ROWS; r++) {
                    for (let c = 0; c < GRID_COLS; c++) {
                        const tile = mapGrid[r][c];
                        const x = c * tileSize;
                        const y = r * tileSize;

                        if (tile === TILE_WALL) {
                            // 강렬한 네온 석조 성벽
                            ctx.fillStyle = '#0f172a';
                            ctx.fillRect(x + 1, y + 1, tileSize - 2, tileSize - 2);
                            ctx.strokeStyle = '#334155';
                            ctx.lineWidth = 1;
                            ctx.strokeRect(x + 1, y + 1, tileSize - 2, tileSize - 2);
                        } else {
                            // 일반 안전 통로 바닥 격자선
                            ctx.fillStyle = '#090d16';
                            ctx.fillRect(x, y, tileSize, tileSize);
                            ctx.strokeStyle = 'rgba(51, 65, 85, 0.15)';
                            ctx.lineWidth = 1;
                            ctx.strokeRect(x, y, tileSize, tileSize);
                        }
                    }
                }

                // 2. 오브젝트 개체 (몬스터, 상자, 포탈, 상점) 렌더링
                entities.forEach(e => {
                    if (!e.active) return;
                    
                    const x = e.x * tileSize + tileSize / 2;
                    const y = e.y * tileSize + tileSize / 2;

                    // 만약 포탈이고, 포탈이 아직 열리지 않았다면 연하게 렌더링
                    if (e.type === TILE_PORTAL && !isPortalOpen) {
                        ctx.save();
                        ctx.globalAlpha = 0.25;
                        ctx.font = `${tileSize * 0.55}px Arial`;
                        ctx.textAlign = 'center';
                        ctx.textBaseline = 'middle';
                        ctx.fillText('🌀', x, y);
                        ctx.restore();
                        return;
                    }

                    // 일반 개체 출력
                    ctx.save();
                    ctx.shadowBlur = 10;
                    ctx.shadowColor = e.type === TILE_MONSTER ? '#ef4444' : '#f59e0b';
                    ctx.font = `${tileSize * 0.6}px Arial`;
                    ctx.textAlign = 'center';
                    ctx.textBaseline = 'middle';
                    ctx.fillText(e.emoji, x, y);

                    // 몬스터 체력 인디케이터 바
                    if (e.type === TILE_MONSTER) {
                        const barW = tileSize * 0.6;
                        const barH = 4;
                        ctx.fillStyle = '#1e293b';
                        ctx.fillRect(x - barW / 2, e.y * tileSize + tileSize - 8, barW, barH);
                        ctx.fillStyle = '#ef4444';
                        ctx.fillRect(x - barW / 2, e.y * tileSize + tileSize - 8, barW * (e.hp / e.maxHp), barH);
                    }
                    ctx.restore();
                });

                // 3. 용사 플레이어 캐릭터 렌더링
                ctx.save();
                ctx.shadowBlur = 15;
                ctx.shadowColor = '#3b82f6';
                const pX = hero.x * tileSize + tileSize / 2;
                const pY = hero.y * tileSize + tileSize / 2;
                ctx.font = `${tileSize * 0.65}px Arial`;
                ctx.textAlign = 'center';
                ctx.textBaseline = 'middle';
                ctx.fillText('👤', pX, pY);
                ctx.restore();

                // 4. 플로팅 격자 이펙트 및 데미지 텍스트
                for (let i = floatingTexts.length - 1; i >= 0; i--) {
                    let ft = floatingTexts[i];
                    ft.y -= 0.8;
                    ft.alpha -= 0.02;
                    ft.life--;

                    if (ft.life <= 0) {
                        floatingTexts.splice(i, 1);
                        continue;
                    }

                    ctx.save();
                    ctx.globalAlpha = ft.alpha;
                    ctx.fillStyle = ft.color;
                    ctx.font = 'bold 12px Orbitron';
                    ctx.textAlign = 'center';
                    ctx.fillText(ft.text, ft.x, ft.y);
                    ctx.restore();
                }
            }

            // --- STREAMING_CHUNK: 조작 및 격자 충돌 감지 비즈니스 로직 ---
            function moveHero(dx, dy) {
                if (hero.hp <= 0) return;

                const nextX = hero.x + dx;
                const nextY = hero.y + dy;

                // 벽 충돌 체크
                if (mapGrid[nextY][nextX] === TILE_WALL) {
                    return; // 성벽 진입 차단
                }

                // 개체와의 상호작용
                const entity = getEntityAt(nextX, nextY);
                if (entity) {
                    interactWithEntity(entity);
                    return; // 턴 행동 완료
                }

                // 이동 실행
                hero.x = nextX;
                hero.y = nextY;
                playSound('move');
                updateHUD();
            }

            function interactWithEntity(entity) {
                if (entity.type === TILE_MONSTER) {
                    // 1. 선제 타격
                    playSound('hit');
                    const dmg = Math.max(1, Math.floor(hero.atk * (0.85 + Math.random() * 0.3)));
                    entity.hp = Math.max(0, entity.hp - dmg);
                    createFloatingText(entity.x, entity.y, `-${dmg}`, '#ef4444');
                    log(`⚔️ 용사의 일격! [${entity.name}]에게 <strong>${dmg}</strong> 피해를 입혔습니다.`);

                    if (entity.hp <= 0) {
                        // 처치 완료 보상 획득
                        entity.active = false;
                        hero.kills++;
                        hero.gold += entity.gold;
                        hero.exp += entity.exp;
                        playSound('coin');
                        log(`🏆 [${entity.name}]을(를) 격퇴했습니다! (🪙+${entity.gold} G / ✨+${entity.exp} EXP)`, 'text-yellow-400');
                        
                        // 레벨업 조건 판별
                        checkLevelUp();
                        // 던전 관문 오픈 체크
                        checkPortalUnlock();
                    } else {
                        // 2. 적의 즉시 반격
                        setTimeout(() => {
                            if (entity.hp > 0 && hero.hp > 0) {
                                playSound('hit');
                                const rawDmg = Math.floor(entity.atk * (0.8 + Math.random() * 0.4));
                                const actualDmg = Math.max(1, rawDmg - hero.def);
                                hero.hp = Math.max(0, hero.hp - actualDmg);
                                createFloatingText(hero.x, hero.y, `-${actualDmg}`, '#f43f5e');
                                log(`💥 [${entity.name}]의 거친 급습! 용사는 <strong>${actualDmg}</strong> 피해를 입었습니다.`, 'text-rose-400');
                                updateHUD();
                                checkGameOver();
                            }
                        }, 250);
                    }
                } else if (entity.type === TILE_CHEST) {
                    // 상자 획득
                    playSound('coin');
                    entity.active = false;
                    const bonusGold = 15 + Math.floor(Math.random() * 20);
                    hero.gold += bonusGold;
                    createFloatingText(entity.x, entity.y, `+${bonusGold}G`, '#fbbf24');
                    log(`🎁 오래된 성궤를 열었습니다! <strong>${bonusGold} Gold</strong>를 획득했습니다.`, 'text-yellow-300');
                } else if (entity.type === TILE_SHOP) {
                    // 상점 진입
                    openShopModal();
                } else if (entity.type === TILE_PORTAL) {
                    // 포탈 이용
                    if (isPortalOpen) {
                        playSound('nextfloor');
                        hero.floor++;
                        generateDungeon();
                    } else {
                        log(`🌀 관문의 마법 인장이 굳게 잠겨있습니다! 던전 안의 모든 몬스터를 먼저 섬멸해야 합니다.`, 'text-emerald-400');
                    }
                }
                updateHUD();
            }

            // --- STREAMING_CHUNK: 관문 해금 및 레벨업 체크 모듈 ---
            function checkPortalUnlock() {
                const aliveMonsters = entities.filter(e => e.type === TILE_MONSTER && e.active).length;
                if (aliveMonsters === 0 && !isPortalOpen) {
                    isPortalOpen = true;
                    // 배너 알림
                    const banner = document.getElementById('portal-banner');
                    banner.classList.remove('hidden');
                    setTimeout(() => banner.classList.add('hidden'), 2500);
                    playSound('heal');
                    log(`🚪 던전 내의 사악한 영혼이 모두 정화되었습니다! 다음 지하 하강 포탈이 활성화되었습니다.`, 'text-emerald-400');
                }
            }

            function checkLevelUp() {
                while (hero.exp >= hero.maxExp) {
                    hero.exp -= hero.maxExp;
                    hero.level++;
                    hero.maxHp = Math.floor(hero.maxHp * 1.25);
                    hero.atk = Math.floor(hero.atk * 1.2) + 1;
                    hero.maxExp = Math.floor(hero.maxExp * 1.45);
                    hero.hp = hero.maxHp; // 만피 전력 충전
                    playSound('levelup');
                    log(`🎉 <strong>LEVEL UP!</strong> 레벨 ${hero.level}이 되었습니다! 능력치가 대폭 상승하고 최대 체력을 회복합니다!`, 'text-yellow-300');
                }
                updateHUD();
            }

            // --- STREAMING_CHUNK: 치유 약물 마시기 로직 ---
            function drinkHealPotion() {
                if (hero.hp <= 0) return;
                if (hero.potions <= 0) {
                    log(`❌ 치유 포션이 바닥났습니다. 상점🏪 타일로 이동하여 보급받으세요.`, 'text-amber-500');
                    return;
                }

                hero.potions--;
                playSound('heal');
                const healAmt = 20;
                hero.hp = Math.min(hero.maxHp, hero.hp + healAmt);
                createFloatingText(hero.x, hero.y, `+${healAmt}`, '#10b981');
                log(`🧪 에메랄드 포션을 단숨에 마셔 지친 기운과 고통을 해소하고 <strong>${healAmt}HP</strong>를 회복했습니다.`, 'text-emerald-400');
                updateHUD();
            }

            // --- STREAMING_CHUNK: 상점 시스템 관리 로직 ---
            function openShopModal() {
                document.getElementById('shop-gold-val').innerText = hero.gold;
                // 물가 태그 갱신
                document.getElementById('shop-atk-cost').innerText = `🪙 ${hero.upgradeCosts.atk}G`;
                document.getElementById('shop-def-cost').innerText = `🪙 ${hero.upgradeCosts.def}G`;
                document.getElementById('shop-pot-cost').innerText = `🪙 ${hero.upgradeCosts.pot}G`;
                
                document.getElementById('shop-screen').classList.remove('hidden');
                log(`🏪 던전의 방랑상인이 예쁜 불빛 밑에서 고대의 비기를 판매합니다.`, 'text-amber-400');
            }

            function closeShopModal() {
                document.getElementById('shop-screen').classList.add('hidden');
                log(`🏪 상점과의 거래가 끝났습니다. 탐색을 계속하십시오.`);
            }

            // 루비소드 구매
            document.getElementById('shop-buy-atk').addEventListener('click', () => {
                if (hero.gold >= hero.upgradeCosts.atk) {
                    hero.gold -= hero.upgradeCosts.atk;
                    hero.atk += 3;
                    hero.upgradeCosts.atk = Math.floor(hero.upgradeCosts.atk * 1.4);
                    playSound('coin');
                    openShopModal(); // 금액 및 가격 갱신 리프레시
                    log(`⚔️ 루비소드 연마 완료! 기본 공격력이 <strong>3</strong>만큼 영구히 증가합니다.`, 'text-yellow-400');
                } else {
                    log(`❌ 상인이 골드가 한참 부족하다며 인상을 찌푸립니다.`);
                }
                updateHUD();
            });

            // 판금갑옷 구매
            document.getElementById('shop-buy-def').addEventListener('click', () => {
                if (hero.gold >= hero.upgradeCosts.def) {
                    hero.gold -= hero.upgradeCosts.def;
                    hero.def += 1;
                    hero.upgradeCosts.def = Math.floor(hero.upgradeCosts.def * 1.4);
                    playSound('coin');
                    openShopModal();
                    log(`🛡️ 판금갑옷 철판 보강 완료! 받는 피해가 항상 <strong>1</strong>만큼 감소합니다.`, 'text-yellow-400');
                } else {
                    log(`❌ 상인이 골드가 한참 부족하다며 인상을 찌푸립니다.`);
                }
                updateHUD();
            });

            // 포션 보급 구매
            document.getElementById('shop-buy-pot').addEventListener('click', () => {
                if (hero.gold >= hero.upgradeCosts.pot) {
                    hero.gold -= hero.upgradeCosts.pot;
                    hero.potions++;
                    playSound('heal');
                    openShopModal();
                    log(`🧪 치유의 포션을 한 개 전술 벨트에 비축했습니다. (보유: ${hero.potions}개)`, 'text-emerald-400');
                } else {
                    log(`❌ 상인이 골드가 한참 부족하다며 인상을 찌푸립니다.`);
                }
                updateHUD();
            });

            // --- STREAMING_CHUNK: 게임오버 및 부활 시스템 ---
            function checkGameOver() {
                if (hero.hp <= 0) {
                    setTimeout(() => {
                        document.getElementById('go-floor').innerText = `B${hero.floor} DEPTHS`;
                        document.getElementById('go-kills').innerText = `${hero.kills} MONSTERS`;
                        document.getElementById('gameover-screen').classList.remove('hidden');
                        log(`💀 기력을 완전히 잃어 어둠 속에 쓰러졌습니다... 영혼의 여정이 마감되었습니다.`, 'text-red-500');
                    }, 500);
                }
            }

            function restartGame() {
                hero = {
                    level: 1, hp: 35, maxHp: 35, atk: 7, def: 0, exp: 0, maxExp: 15, gold: 30, potions: 1, kills: 0, floor: 1,
                    upgrades: { atk: 0, def: 0, pot: 0 },
                    upgradeCosts: { atk: 30, def: 40, pot: 15 }
                };
                document.getElementById('gameover-screen').classList.add('hidden');
                document.getElementById('combat-log').innerHTML = '<div class="text-sky-400 font-bold">🛡️ 다시 한 번 용기 내어 가상 네온 던전 입구에 섰습니다!</div>';
                generateDungeon();
            }

            // --- STREAMING_CHUNK: 조작 및 이벤트 바인딩 통합 ---
            
            // 키보드 입력 매핑
            window.addEventListener('keydown', (e) => {
                if (document.getElementById('start-screen').classList.contains('hidden') === false) return;
                if (document.getElementById('shop-screen').classList.contains('hidden') === false) return;
                if (document.getElementById('gameover-screen').classList.contains('hidden') === false) return;

                if (e.key === 'ArrowUp' || e.key === 'w' || e.key === 'W') moveHero(0, -1);
                if (e.key === 'ArrowDown' || e.key === 's' || e.key === 'S') moveHero(0, 1);
                if (e.key === 'ArrowLeft' || e.key === 'a' || e.key === 'A') moveHero(-1, 0);
                if (e.key === 'ArrowRight' || e.key === 'd' || e.key === 'D') moveHero(1, 0);
            });

            // 하단 조이패드(D-pad) 마우스 및 터치 리스너
            document.getElementById('btn-up').addEventListener('click', () => moveHero(0, -1));
            document.getElementById('btn-down').addEventListener('click', () => moveHero(0, 1));
            document.getElementById('btn-left').addEventListener('click', () => moveHero(-1, 0));
            document.getElementById('btn-right').addEventListener('click', () => moveHero(1, 0));

            // 기타 유틸리티 단추 바인딩
            document.getElementById('btn-potion').addEventListener('click', drinkHealPotion);
            document.getElementById('btn-shop-close').addEventListener('click', closeShopModal);

            document.getElementById('btn-start').addEventListener('click', () => {
                document.getElementById('start-screen').classList.add('hidden');
                audioCtx.resume();
                generateDungeon();
            });

            document.getElementById('btn-retry').addEventListener('click', restartGame);

            // --- STREAMING_CHUNK: 메인 드로잉 틱 개시 ---
            function renderLoop() {
                drawDungeon();
                requestAnimationFrame(renderLoop);
            }

            renderLoop();
        })();
    </script>
</body>
</html>
